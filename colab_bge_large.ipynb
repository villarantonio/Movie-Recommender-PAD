  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =============================================================\n",
    "# CONFIGURACAO — ajuste os caminhos se necessario\n",
    "# =============================================================\n",
    "DATA_DIR   = '/content/drive/MyDrive/ml-25m'   # pasta com os CSVs do MovieLens\n",
    "CACHE_PATH = '/content/drive/MyDrive/embeddings_bge_large.npy'  # cache persistente no Drive\n",
    "MODEL_NAME = 'BAAI/bge-large-en-v1.5'\n",
    "\n",
    "import os\n",
    "assert os.path.exists(DATA_DIR), (\n",
    "    f'Pasta nao encontrada: {DATA_DIR}\\n'\n",
    "    'Faca upload da pasta ml-25m/ para o Google Drive e ajuste DATA_DIR acima.'\n",
    ")\n",
    "print('Dados encontrados em:', DATA_DIR)\n",
    "print('Cache de embeddings:', CACHE_PATH)\n",
    "print('Modelo:', MODEL_NAME)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Preprocessamento — construcao da coluna `soup`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.preprocess import build_soup\n",
    "\n",
    "df = build_soup(DATA_DIR)\n",
    "print(f'Total de filmes: {len(df)}')\n",
    "df.head(3)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Embeddings — bge-large-en-v1.5 em todos os 62k filmes\n",
    "\n",
    "Na T4 (16 GB VRAM) com `batch_size=256` leva **~3–5 minutos**.  \n",
    "O cache e salvo no Drive; execucoes seguintes carregam instantaneamente."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import time\n",
    "\n",
    "if os.path.exists(CACHE_PATH):\n",
    "    print(f'[embeddings] Carregando cache: {CACHE_PATH}')\n",
    "    embeddings = np.load(CACHE_PATH)\n",
    "    print(f'[embeddings] Shape: {embeddings.shape}')\n",
    "else:\n",
    "    from sentence_transformers import SentenceTransformer\n",
    "\n",
    "    print(f'[embeddings] Carregando modelo {MODEL_NAME} ...')\n",
    "    model = SentenceTransformer(MODEL_NAME, device='cuda')\n",
    "\n",
    "    print(f'[embeddings] Gerando embeddings para {len(df)} filmes ...')\n",
    "    t0 = time.time()\n",
    "    embeddings = model.encode(\n",
    "        df['soup'].tolist(),\n",
    "        batch_size=256,          # GPU comporta batches maiores\n",
    "        show_progress_bar=True,\n",
    "        normalize_embeddings=True,\n",
    "        device='cuda',\n",
    "    )\n",
    "    elapsed = time.time() - t0\n",
    "    print(f'[embeddings] Concluido em {elapsed:.1f}s. Shape: {embeddings.shape}')\n",
    "    np.save(CACHE_PATH, embeddings)\n",
    "    print(f'[embeddings] Cache salvo em: {CACHE_PATH}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Benchmark — The Prestige (2006)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
