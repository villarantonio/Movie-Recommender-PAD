   "source": [
    "from src.recommender import build_cosine_matrix\n",
    "from src.benchmark import run_benchmark\n",
    "\n",
    "cosine_sim = build_cosine_matrix(embeddings)\n",
    "run_benchmark(df, cosine_sim, model_name=MODEL_NAME)"
   ]
  },
